            <Area type="monotone" dataKey="actual" stroke={G.accent} strokeWidth={2.5} fill="url(#g2)" dot={{ fill:G.accent,r:3 }} name="actual"/>
            <Area type="monotone" dataKey="projected" stroke={G.accent} strokeWidth={1.5} strokeDasharray="5 3" fill="none" dot={false} name="projected" opacity={.45}/>
          </AreaChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
}

