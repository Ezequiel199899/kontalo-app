function MarketsPage({ fx, commodities, fxLoading, fxError, fxDate, onRefresh }) {
  const [amount,setAmount]=useState("1000"); const [from,setFrom]=useState("USD"); const [to,setTo]=useState("ARS");
  const pairs=["USD","EUR","ARS","BRL","MXN","GBP","CNY"];
  const currencies=[
    { code:"EUR", name:"Euro",           flag:"🇪🇺", rate:fx?.EUR?`${fx.EUR.toFixed(4)} EUR`:"—" },
    { code:"ARS", name:"Argentine Peso", flag:"🇦🇷", rate:fx?.ARS?`${fx.ARS.toFixed(2)} ARS`:"—" },
    { code:"BRL", name:"Brazilian Real", flag:"🇧🇷", rate:fx?.BRL?`${fx.BRL.toFixed(4)} BRL`:"—" },
    { code:"MXN", name:"Mexican Peso",   flag:"🇲🇽", rate:fx?.MXN?`${fx.MXN.toFixed(4)} MXN`:"—" },
    { code:"COP", name:"Colombian Peso", flag:"🇨🇴", rate:fx?.COP?`${fx.COP.toFixed(0)} COP`:"—" },
    { code:"CLP", name:"Chilean Peso",   flag:"🇨🇱", rate:fx?.CLP?`${fx.CLP.toFixed(0)} CLP`:"—" },
    { code:"GBP", name:"British Pound",  flag:"🇬🇧", rate:fx?.GBP?`${fx.GBP.toFixed(4)} GBP`:"—" },
    { code:"CNY", name:"Chinese Yuan",   flag:"🇨🇳", rate:fx?.CNY?`${fx.CNY.toFixed(4)} CNY`:"—" },
  ];
  const comCards=[
    { name:"Gold",      unit:"troy oz", icon:"🥇", val:commodities?.goldUSD?`$${commodities.goldUSD.toLocaleString()}`:"$3,342", live:!!commodities?.goldUSD },
    { name:"Silver",    unit:"troy oz", icon:"🥈", val:commodities?.silverUSD?`$${commodities.silverUSD.toFixed(2)}`:"$32.40",   live:!!commodities?.silverUSD },
    { name:"Crude Oil", unit:"barrel",  icon:"🛢️", val:"$73.40", live:false },
    { name:"Soybeans",  unit:"bushel",  icon:"🌾", val:"$10.82", live:false },
    { name:"Wheat",     unit:"bushel",  icon:"🌿", val:"$5.64",  live:false },
    { name:"Corn",      unit:"bushel",  icon:"🌽", val:"$4.38",  live:false },
  ];
  const convert=()=>{ const amt=parseFloat(amount)||0; if(!fx)return"—"; const toUSD=from==="USD"?amt:from==="EUR"?amt*(1/fx.EUR):amt/(fx[from]||1); const res=to==="USD"?toUSD:to==="EUR"?toUSD*fx.EUR:toUSD*(fx[to]||1); return res.toLocaleString("en-US",{maximumFractionDigits:2}); };
  const sel=(val,onChange)=><select value={val} onChange={e=>onChange(e.target.value)} style={{ background:G.bg, border:`1px solid ${G.border}`, color:G.text, borderRadius:6, padding:".5rem .7rem", fontSize:".85rem", cursor:"pointer", outline:"none" }}>{pairs.map(p=><option key={p}>{p}</option>)}</select>;
  return (
    <div className="fade-in">
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start", marginBottom:"1.75rem" }}>
        <div><h1 style={{ fontFamily:G.fontDisplay, fontSize:"1.5rem", fontWeight:700 }}>FX & Markets</h1><p style={{ color:G.muted, fontSize:".85rem", marginTop:".2rem" }}>Frankfurter (ECB) · {fxDate?`Updated ${fxDate}`:"—"}</p></div>
        <button className="btn btn-ghost" onClick={onRefresh} disabled={fxLoading}>{fxLoading?<><Spin/> Refreshing</>:"↻ Refresh"}</button>
      </div>
      {fxError&&<div className="card" style={{ padding:".9rem 1.25rem", marginBottom:"1.25rem", borderColor:G.danger+"44", fontSize:".85rem", color:G.danger }}>⚠ {fxError}</div>}
      <div style={{ fontFamily:G.fontDisplay, fontWeight:600, fontSize:"1rem", marginBottom:"1rem" }}>Currency Pairs</div>
      <div className="fx-grid" style={{ display:"grid", gridTemplateColumns:"repeat(4,1fr)", gap:".85rem", marginBottom:"2rem" }}>
        {currencies.map(c=>(<div key={c.code} className="fx-card"><div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:".5rem" }}><span style={{ fontSize:"1.4rem" }}>{c.flag}</span><span className="badge badge-green">{c.code}</span></div><div style={{ fontSize:".75rem", color:G.faint, marginBottom:".2rem" }}>{c.name}</div><div style={{ fontFamily:G.fontDisplay, fontWeight:700, fontSize:"1.15rem" }}>{fxLoading?"—":c.rate}</div></div>))}
      </div>
      <div style={{ fontFamily:G.fontDisplay, fontWeight:600, fontSize:"1rem", marginBottom:"1rem" }}>Commodities</div>
      <div className="fx-grid" style={{ display:"grid", gridTemplateColumns:"repeat(3,1fr)", gap:".85rem", marginBottom:"2rem" }}>
        {comCards.map(c=>(<div key={c.name} className="fx-card"><div style={{ fontSize:"1.5rem", marginBottom:".5rem" }}>{c.icon}</div><div style={{ fontSize:".75rem", color:G.faint, marginBottom:".2rem" }}>{c.name} / {c.unit}</div><div style={{ fontFamily:G.fontDisplay, fontWeight:700, fontSize:"1.3rem", color:G.accent }}>{c.val}</div><div style={{ fontSize:".65rem", color:G.faint, marginTop:".3rem" }}>{c.live?"● Live":"○ Reference"}</div></div>))}
      </div>
      <div className="card" style={{ padding:"1.5rem" }}>
        <div style={{ fontFamily:G.fontDisplay, fontWeight:600, marginBottom:"1.25rem" }}>Currency Converter</div>
        <div style={{ display:"flex", gap:"1rem", alignItems:"center", flexWrap:"wrap" }}>
          <input className="input" style={{ maxWidth:160 }} type="number" value={amount} onChange={e=>setAmount(e.target.value)}/>
          {sel(from,setFrom)}<span style={{ color:G.muted, fontSize:"1.2rem" }}>→</span>{sel(to,setTo)}
          <div style={{ fontFamily:G.fontDisplay, fontSize:"1.4rem", fontWeight:700, color:G.accent }}>{fx?convert():"—"} {to}</div>
        </div>
      </div>
    </div>
  );
}

